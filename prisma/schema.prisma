generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  activities     Activity[]
  connections    TrackerConnection[]
  workoutPlans   WorkoutPlan[]
  whoopRecoveries WhoopRecovery[]

  mcpToken    String?  @unique // auth token for MCP endpoint
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TrackerConnection {
  id             String    @id @default(cuid())
  userId         String
  provider       String    // "garmin" | "whoop" | "apple" | "coros"
  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  garminUsername   String?
  garminPassword   String?   // encrypted
  stravaAthleteId  String?   // Strava numeric athlete id — used to route webhook events
  connected        Boolean   @default(true)
  connectedAt    DateTime  @default(now())
  lastSyncAt     DateTime?
  // JSON: {"syncActivities":true,"syncRecovery":true,"syncSleep":true}
  dataPrefs      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  garminId    String?  @unique
  whoopId     String?  @unique
  stravaId    String?  @unique
  source      String   @default("garmin") // "garmin" | "whoop" | "strava" | "manual"
  name        String
  type        String   // "running" | "cycling" | "swimming" | "strength"
  startTime   DateTime
  duration    Int      // seconds
  distance    Float?   // meters
  calories    Int?
  avgHeartRate Int?
  maxHeartRate Int?
  avgPace     Float?   // seconds per meter
  bestPace    Float?
  elevGain    Float?
  elevLoss    Float?
  steps       Int?
  rawData     String?  // JSON blob of full Garmin response
  routePoints String?  // JSON array of {lat, lon} — downsampled GPS polyline
  minHeartRate Int?
  hrStream    String?  // JSON [{t: secs_offset, bpm: number}, ...] downsampled ~10s intervals
  hrZones     String?  // JSON {z1: secs, z2: secs, z3: secs, z4: secs, z5: secs}
  createdAt   DateTime @default(now())

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  laps  ActivityLap[]
  links PlanActivityLink[]
}

// ─── Workout Plan ────────────────────────────────────────────────────────────

enum WeekType {
  REGULAR
  PEAK
  TAPER
  RECOVERY
  DELOAD
}

enum DayType {
  REGULAR
  RACE
  REST
  RECOVERY
}

enum DayStatus {
  PLANNED
  COMPLETED
  SKIPPED
  PARTIAL
}

enum EntryType {
  RUN
  CYCLING
  SWIMMING
  STRENGTH
  HIIT
  OTHER
}

enum LinkStatus {
  AUTO      // matched and linked automatically by reconciler
  SUGGESTED // reconciler found a candidate, awaiting user confirmation
  MANUAL    // user explicitly linked this activity
  REJECTED  // user rejected a suggestion (never auto-link again)
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(false)
  isDraft     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks WorkoutWeek[]
}

model WorkoutWeek {
  id          String   @id @default(cuid())
  planId      String
  weekNumber  Int      // 1-based
  type        WeekType @default(REGULAR)
  title       String?
  notes       String?

  plan WorkoutPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  days WorkoutDay[]

  @@unique([planId, weekNumber])
}

model WorkoutDay {
  id          String    @id @default(cuid())
  weekId      String
  dayOfWeek   Int       // 1=Mon … 7=Sun
  type        DayType   @default(REGULAR)
  status      DayStatus @default(PLANNED)
  coachNotes  String?
  completedAt DateTime?

  week    WorkoutWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  entries WorkoutEntry[]

  @@unique([weekId, dayOfWeek])
}

model WorkoutEntry {
  id          String    @id @default(cuid())
  dayId       String
  type        EntryType @default(OTHER)
  title       String
  description String?   // freeform: stations, sets, instructions etc.
  durationMin Int?      // optional planned duration in minutes
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())

  day   WorkoutDay         @relation(fields: [dayId], references: [id], onDelete: Cascade)
  links PlanActivityLink[]
}

model PlanActivityLink {
  id          String     @id @default(cuid())
  entryId     String
  activityId  String
  confidence  Float      // 0.0–1.0 — scoring confidence from reconciler
  status      LinkStatus @default(AUTO)
  createdAt   DateTime   @default(now())

  entry    WorkoutEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  activity Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([entryId, activityId])
}

// ─── WHOOP Recovery / Sleep / Strain ─────────────────────────────────────────

model WhoopRecovery {
  id            String    @id @default(cuid())
  userId        String
  whoopCycleId  Int
  date          DateTime  // start of the WHOOP cycle/day
  // Recovery
  recoveryScore Int?      // 0–100
  hrv           Float?    // hrv_rmssd_milli
  restingHR     Int?
  spo2          Float?    // percentage
  skinTemp      Float?    // celsius
  // Sleep
  sleepId       String?   // UUID in WHOOP v2
  totalSleepMin Int?
  remMin        Int?
  deepMin       Int?
  lightMin      Int?
  awakeMin      Int?
  sleepScore    Int?      // sleep_performance_percentage
  sleepEff      Float?    // sleep_efficiency_percentage
  // Strain / Cycle
  strain        Float?    // 0–21
  kilojoule     Float?
  avgHR         Int?
  maxHR         Int?
  cycleEnd      DateTime?
  rawData       String?   // full JSON blob
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, whoopCycleId])
}

// ─── Activity Laps ────────────────────────────────────────────────────────────

model ActivityLap {
  id           String   @id @default(cuid())
  activityId   String
  lapIndex     Int
  distance     Float    // meters
  duration     Int      // seconds
  avgHeartRate Int?
  maxHeartRate Int?
  avgPace      Float?   // seconds per meter
  zone         Int?     // 1-5
  startTime    DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, lapIndex])
}
