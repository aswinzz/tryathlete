generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  activities  Activity[]
  connections TrackerConnection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TrackerConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "garmin" | "apple" | "coros" | "whoop"
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  garminUsername String?
  garminPassword String? // encrypted
  connectedAt  DateTime @default(now())
  lastSyncAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  garminId    String?  @unique
  name        String
  type        String   // "running" | "cycling" | "swimming" | "strength"
  startTime   DateTime
  duration    Int      // seconds
  distance    Float?   // meters
  calories    Int?
  avgHeartRate Int?
  maxHeartRate Int?
  avgPace     Float?   // seconds per meter
  bestPace    Float?
  elevGain    Float?
  elevLoss    Float?
  steps       Int?
  rawData     String?  // JSON blob of full Garmin response
  createdAt   DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  laps ActivityLap[]
}

model ActivityLap {
  id           String   @id @default(cuid())
  activityId   String
  lapIndex     Int
  distance     Float    // meters
  duration     Int      // seconds
  avgHeartRate Int?
  maxHeartRate Int?
  avgPace      Float?   // seconds per meter
  zone         Int?     // 1-5
  startTime    DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, lapIndex])
}
